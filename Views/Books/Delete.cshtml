@model LibraryHub.Models.Book

@{
    ViewData["Title"] = "Kitabı Sil";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Kitabı Sil</h1>
        <p class="page-subtitle">Bu kayıt silindikten sonra listeden kaldırılır.</p>
    </div>
</div>

<div class="detail-card">
    <div class="delete-warning mb-3">Bu kitabı silmek istediğinizden emin misiniz?</div>

    <dl class="detail-list mb-3">
        <div class="detail-row">
            <dt class="detail-label">Kitap Adı</dt>
            <dd class="detail-value mb-0">@Model.Title</dd>
        </div>
        <div class="detail-row">
            <dt class="detail-label">Kategori</dt>
            <dd class="detail-value mb-0">@Model.Category?.Name</dd>
        </div>
        <div class="detail-row">
            <dt class="detail-label">Yazar</dt>
            <dd class="detail-value mb-0">@Model.Author?.FullName</dd>
        </div>
    </dl>

    <form asp-action="Delete" class="action-group">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Sil</button>
        <a asp-action="Index" class="btn btn-secondary">Vazgeç</a>
    </form>
</div>
