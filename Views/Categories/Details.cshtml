@model LibraryHub.Models.Category

@{
    ViewData["Title"] = "Kategori Detayı";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Kategori Detayı</h1>
        <p class="page-subtitle">Seçili kategori kaydının özeti.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Düzenle</a>
        <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
    </div>
</div>

<div class="detail-card">
    <dl class="detail-list">
        <div class="detail-row">
            <dt class="detail-label">Kategori Adı</dt>
            <dd class="detail-value mb-0">@Model?.Name</dd>
        </div>
    </dl>
</div>
